@model SWD392_PROJECT.ViewModels.IssueListViewModel

@{
    ViewData["Title"] = "Issues";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h2">Issue Reports</h1>
            </div>

            <!-- Filter Options -->
            <div class="card shadow-sm mb-4 border-0">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <a href="@Url.Action("List", "Issue")" class="btn btn-outline-primary">
                                All Issues (@Model.TotalCount)
                            </a>
                        </div>
                        <div class="col-md-6">
                            <div class="btn-group">
                                <a href="@Url.Action("List", "Issue", new { status = "Open" })" 
                                   class="btn @(Model.FilterStatus == "Open" ? "btn-primary" : "btn-outline-primary")">
                                    Open
                                </a>
                                <a href="@Url.Action("List", "Issue", new { status = "In Progress" })" 
                                   class="btn @(Model.FilterStatus == "In Progress" ? "btn-primary" : "btn-outline-primary")">
                                    In Progress
                                </a>
                                <a href="@Url.Action("List", "Issue", new { status = "Resolved" })" 
                                   class="btn @(Model.FilterStatus == "Resolved" ? "btn-primary" : "btn-outline-primary")">
                                    Resolved
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Issues Table -->
            @if (Model.Issues.Any())
            {
                <div class="table-responsive shadow-sm border-0">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Issue ID</th>
                                <th>Order ID</th>
                                <th>Student</th>
                                <th>Description</th>
                                <th>Status</th>
                                <th>Notifications</th>
                                <th>Reported</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var issue in Model.Issues)
                            {
                                <tr>
                                    <td><span class="badge bg-info">#@issue.IssueId</span></td>
                                    <td>#@issue.OrderId</td>
                                    <td>@issue.StudentName</td>
                                    <td>
                                        <small>@issue.Details.Substring(0, Math.Min(50, issue.Details.Length))...</small>
                                    </td>
                                    <td>
                                        @{
                                            var statusClass = issue.Status switch
                                            {
                                                "Open" => "bg-danger",
                                                "In Progress" => "bg-warning",
                                                "Resolved" => "bg-success",
                                                "Closed" => "bg-secondary",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @statusClass">@issue.Status</span>
                                    </td>
                                    <td>
                                        @if (issue.NotificationCount > 0)
                                        {
                                            <span class="badge bg-info">@issue.NotificationCount</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        <small class="text-muted">@issue.CreatedDate.ToString("MMM dd, yyyy")</small>
                                    </td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@issue.IssueId" class="btn btn-sm btn-primary">
                                            View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center py-5">
                    <h5>No Issues Found</h5>
                    <p class="mb-0">There are no issue reports @(!string.IsNullOrEmpty(Model.FilterStatus) ? $"with status '{Model.FilterStatus}'" : "at this time").</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .table {
        border-collapse: collapse;
    }

    .table thead th {
        border-bottom: 2px solid #e1e5eb;
        font-weight: 600;
        color: #333;
    }

    .table tbody tr {
        border-bottom: 1px solid #e1e5eb;
        transition: background-color 0.3s ease;
    }

    .table tbody tr:hover {
        background-color: #f9fafb;
    }

    .badge {
        padding: 0.4rem 0.8rem;
        border-radius: 6px;
        font-weight: 500;
    }

    .btn-group .btn {
        border-radius: 6px;
        margin-right: 0.5rem;
    }

    .btn-outline-primary {
        color: #0061ff;
        border-color: #0061ff;
    }

    .btn-outline-primary:hover {
        background-color: #0061ff;
        color: white;
    }

    .btn-primary {
        background-color: #0061ff;
        border-color: #0061ff;
    }

    .btn-primary:hover {
        background-color: #0052d4;
        border-color: #0052d4;
    }
</style>
