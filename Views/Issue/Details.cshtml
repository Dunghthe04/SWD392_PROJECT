@model SWD392_PROJECT.ViewModels.IssueDetailViewModel

@{
    ViewData["Title"] = $"Issue #{Model.IssueId}";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-8">
            <!-- Issue Details Card -->
            <div class="card shadow-lg border-0 mb-4">
                <div class="card-header bg-primary text-white">
                    <div class="row align-items-center">
                        <div class="col">
                            <h2 class="mb-0">Issue #@Model.IssueId</h2>
                        </div>
                        <div class="col-auto">
                            @{
                                var statusClass = Model.Status switch
                                {
                                    "Open" => "bg-danger",
                                    "In Progress" => "bg-warning",
                                    "Resolved" => "bg-success",
                                    "Closed" => "bg-secondary",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @statusClass">@Model.Status</span>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4">
                    <!-- Order Info -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h6 class="text-muted">Order</h6>
                            <p class="h5">#@Model.OrderId</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Student</h6>
                            <p class="h5">@Model.StudentName</p>
                        </div>
                    </div>

                    <hr />

                    <!-- Issue Details -->
                    <div class="mb-4">
                        <h6 class="text-muted">Issue Description</h6>
                        <p class="h6">@Model.Details</p>
                    </div>

                    <!-- Evidence Image -->
                    @if (!string.IsNullOrEmpty(Model.ImagePath))
                    {
                        <div class="mb-4">
                            <h6 class="text-muted">Evidence Image</h6>
                            <img src="@Model.ImagePath" alt="Issue Evidence" class="img-fluid rounded" style="max-height: 400px;" />
                        </div>
                    }

                    <!-- Timeline -->
                    <div class="mb-4">
                        <h6 class="text-muted">Timeline</h6>
                        <div class="row">
                            <div class="col-6">
                                <small class="text-muted">Reported On</small>
                                <p>@Model.CreatedDate.ToString("MMM dd, yyyy HH:mm")</p>
                            </div>
                            <div class="col-6">
                                <small class="text-muted">Last Updated</small>
                                <p>@Model.LastUpdatedDate.ToString("MMM dd, yyyy HH:mm")</p>
                            </div>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-flex gap-2 mt-5">
                        <a href="@Url.Action("List", "Issue")" class="btn btn-outline-secondary">
                            Back to Issues
                        </a>
                        <a href="@Url.Action("Index", "OrderManagement")" class="btn btn-outline-primary">
                            View Order
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Notifications Sidebar -->
        <div class="col-lg-4">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="bi bi-bell"></i> Notifications
                        @if (Model.Notifications.Any())
                        {
                            <span class="badge bg-danger">@Model.Notifications.Count</span>
                        }
                    </h5>
                </div>

                <div class="card-body p-0">
                    @if (Model.Notifications.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var notification in Model.Notifications)
                            {
                                <div class="list-group-item @(notification.IsRead ? "bg-light" : "bg-white")">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="flex-grow-1">
                                            @if (!notification.IsRead)
                                            {
                                                <span class="badge bg-primary me-2">New</span>
                                            }
                                            <p class="mb-1">@notification.Message</p>
                                            <small class="text-muted">@notification.CreatedDate.ToString("MMM dd, yyyy HH:mm")</small>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="p-3 text-center text-muted">
                            <small>No notifications yet</small>
                        </div>
                    }
                </div>
            </div>

            <!-- Status Update Card (for managers) -->
            <div class="card shadow-lg border-0 mt-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Update Status</h5>
                </div>

                <div class="card-body">
                    <form asp-action="UpdateStatus" method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="IssueId" />

                        <div class="mb-3">
                            <label for="newStatus" class="form-label">Status</label>
                            <select name="NewStatus" id="newStatus" class="form-select">
                                <option value="">Select Status</option>
                                <option value="Open" selected="@(Model.Status == "Open")">Open</option>
                                <option value="In Progress" selected="@(Model.Status == "In Progress")">In Progress</option>
                                <option value="Resolved" selected="@(Model.Status == "Resolved")">Resolved</option>
                                <option value="Closed" selected="@(Model.Status == "Closed")">Closed</option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Update Status</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border: none;
        border-radius: 12px;
    }

    .card-header {
        border-radius: 12px 12px 0 0;
    }

    .badge {
        padding: 0.4rem 0.8rem;
        border-radius: 6px;
        font-weight: 500;
    }

    .list-group-item {
        border: none;
        border-bottom: 1px solid #e1e5eb;
    }

    .list-group-item:last-child {
        border-bottom: none;
    }

    .form-select {
        border-radius: 6px;
        border: 1px solid #e1e5eb;
        padding: 0.75rem 1rem;
    }

    .form-select:focus {
        border-color: #0061ff;
        box-shadow: 0 0 0 0.2rem rgba(0, 97, 255, 0.25);
    }

    .btn-primary {
        background-color: #0061ff;
        border-color: #0061ff;
    }

    .btn-primary:hover {
        background-color: #0052d4;
        border-color: #0052d4;
    }

    img {
        border: 1px solid #e1e5eb;
    }
</style>
