@model SWD392_PROJECT.Models.EditOrderViewModel
@{
    ViewData["Title"] = "Update Order";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-10 mx-auto">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Update Order #@Model.OrderId</h4>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <p class="mb-1"><small class="text-muted">Student Name</small></p>
                            <p class="fs-5"><strong>@Model.StudentName</strong></p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-1"><small class="text-muted">Status</small></p>
                            <p class="fs-5">
                                @{
                                    var statusClass = Model.Status switch
                                    {
                                        "Pending" => "badge bg-warning text-dark",
                                        "Completed" => "badge bg-success",
                                        "Cancelled" => "badge bg-secondary",
                                        "Processing" => "badge bg-info",
                                        _ => "badge bg-secondary"
                                    };
                                }
                                <span class="@statusClass">@Model.Status</span>
                            </p>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.Message))
                    {
                        var alertClass = Model.IsConflict ? "alert-warning" : "alert-danger";
                        <div class="alert @alertClass alert-dismissible fade show" role="alert">
                            @Model.Message
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="OrderId" />
                        <input type="hidden" asp-for="Version" />
                        <input type="hidden" asp-for="StudentName" />
                        <input type="hidden" asp-for="Status" />

                        <div class="mb-4">
                            <label asp-for="Notes" class="form-label fw-bold">Order Notes</label>
                            <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Add any special instructions or notes..."></textarea>
                            <small class="form-text text-muted">Max 500 characters</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Order Items</label>
                            <div class="table-responsive">
                                <table class="table table-bordered">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Item Name</th>
                                            <th style="width: 150px;">Unit Price</th>
                                            <th style="width: 150px;">Quantity</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    @for (var i = 0; i < Model.Items.Count; i++)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@Model.Items[i].ItemName</strong>
                                                <input type="hidden" asp-for="Items[i].MenuItemId" />
                                                <input type="hidden" asp-for="Items[i].ItemName" />
                                            </td>
                                            <td class="text-end">
                                                @Model.Items[i].UnitPrice.ToString("N0") VND
                                                <input type="hidden" asp-for="Items[i].UnitPrice" />
                                            </td>
                                            <td>
                                                <input asp-for="Items[i].Quantity" class="form-control form-control-sm" type="number" min="1" />
                                            </td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" name="submitAction" value="save" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-lg"></i> Save Changes
                            </button>
                            <button type="submit" name="submitAction" value="cancel" class="btn btn-secondary btn-lg">
                                <i class="bi bi-x-lg"></i> Cancel
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg ms-auto">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }
    
    .table-responsive {
        border-radius: 0.375rem;
    }
</style>
