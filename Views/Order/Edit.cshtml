@model SWD392_PROJECT.Models.EditOrderViewModel
@{
    ViewData["Title"] = "Update Order";
}

<div class="container-fluid edit-order-page">
    <div class="row">
        <div class="col-xl-10 col-lg-11 mx-auto">
            <div class="edit-shell">
                <div class="edit-header">
                    <div>
                        <p class="edit-subtitle mb-1">Order Management</p>
                        <h1 class="edit-title mb-0">Update Order #@Model.OrderId</h1>
                    </div>
                    <a asp-action="Index" class="btn btn-outline-light back-btn">Back to List</a>
                </div>

                <div class="edit-body">
                    @if (!string.IsNullOrWhiteSpace(Model.Message))
                    {
                        var alertClass = Model.IsConflict ? "alert-warning" : "alert-danger";
                        <div class="alert @alertClass alert-dismissible fade show mb-4" role="alert">
                            @Model.Message
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="Edit" method="post" id="editOrderForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="OrderId" />
                        <input type="hidden" asp-for="Version" />
                        <input type="hidden" asp-for="StudentName" />

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label">Student Name</label>
                                <input class="form-control" value="@Model.StudentName" disabled />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Status" class="form-label">Status</label>
                                <select asp-for="Status" class="form-select">
                                    <option value="Pending">Pending</option>
                                    <option value="Processing">Processing</option>
                                    <option value="Completed">Completed</option>
                                    <option value="Cancelled">Cancelled</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Notes" class="form-label">Order Notes</label>
                            <textarea asp-for="Notes" class="form-control notes-input" rows="3" placeholder="Add any special instructions or notes..."></textarea>
                            <div class="form-text">Maximum 500 characters.</div>
                        </div>

                        <div class="item-section">
                            <div class="item-section-header">
                                <h2 class="item-section-title mb-0">Order Items</h2>
                                <div class="total-preview">Total: <strong id="orderTotal">0 VND</strong></div>
                            </div>
                            <div class="table-responsive">
                                <table class="table align-middle item-table">
                                    <thead>
                                        <tr>
                                            <th>Item Name</th>
                                            <th class="price-col">Unit Price</th>
                                            <th class="qty-col">Quantity</th>
                                            <th class="line-col">Line Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    @for (var i = 0; i < Model.Items.Count; i++)
                                    {
                                        <tr>
                                            <td>
                                                <input type="hidden" asp-for="Items[i].MenuItemId" />
                                                <input asp-for="Items[i].ItemName" class="form-control form-control-sm item-name" type="text" maxlength="255" />
                                            </td>
                                            <td>
                                                <input asp-for="Items[i].UnitPrice" class="form-control form-control-sm unit-price" type="number" min="1" step="1000" />
                                            </td>
                                            <td>
                                                <input asp-for="Items[i].Quantity" class="form-control form-control-sm quantity" type="number" min="1" />
                                            </td>
                                            <td>
                                                <span class="line-total">0 VND</span>
                                            </td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="action-row">
                            <button type="submit" name="submitAction" value="save" class="btn btn-primary px-4">
                                Save Changes
                            </button>
                            <button type="submit" name="submitAction" value="cancel" class="btn btn-outline-secondary px-4">
                                Cancel
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .edit-order-page {
        padding: 2rem 1rem;
        background: linear-gradient(180deg, #f2f7ff 0%, #ffffff 50%);
        min-height: calc(100vh - 120px);
    }

    .edit-shell {
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 8px 28px rgba(14, 28, 56, 0.12);
        border: 1px solid #dbe6ff;
        background: #fff;
    }

    .edit-header {
        background: linear-gradient(135deg, #1f5eff 0%, #1249d6 100%);
        color: #fff;
        padding: 1.25rem 1.5rem;
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
    }

    .edit-subtitle {
        opacity: 0.9;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .edit-title {
        font-size: 1.5rem;
        font-weight: 700;
    }

    .back-btn {
        border-color: rgba(255, 255, 255, 0.45);
        color: #fff;
    }

    .back-btn:hover {
        background: rgba(255, 255, 255, 0.15);
        color: #fff;
        border-color: rgba(255, 255, 255, 0.65);
    }

    .edit-body {
        padding: 1.5rem;
    }

    .notes-input {
        resize: vertical;
    }

    .item-section {
        border: 1px solid #e6ecf7;
        border-radius: 12px;
        overflow: hidden;
        background: #fbfdff;
    }

    .item-section-header {
        padding: 0.85rem 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #f1f6ff;
        border-bottom: 1px solid #e3ebfb;
    }

    .item-section-title {
        font-size: 1rem;
        font-weight: 700;
    }

    .total-preview {
        font-size: 0.95rem;
        color: #0f3fb3;
    }

    .item-table {
        margin-bottom: 0;
    }

    .item-table thead th {
        background: #f8fbff;
        color: #42556b;
        border-bottom: 1px solid #e6ecf7;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .price-col, .qty-col, .line-col {
        width: 145px;
    }

    .line-total {
        font-weight: 600;
        color: #14532d;
        font-size: 0.9rem;
    }

    .action-row {
        margin-top: 1rem;
        display: flex;
        gap: 0.75rem;
        justify-content: flex-end;
    }

    @@media (max-width: 768px) {
        .edit-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .edit-title {
            font-size: 1.25rem;
        }

        .action-row {
            justify-content: stretch;
            flex-direction: column;
        }

        .action-row .btn {
            width: 100%;
        }

        .price-col, .qty-col, .line-col {
            width: auto;
        }
    }
</style>

<script>
    (function () {
        function formatVnd(value) {
            return new Intl.NumberFormat('vi-VN').format(value) + ' VND';
        }

        function parseNumber(input) {
            const value = Number(input.value);
            return Number.isFinite(value) ? value : 0;
        }

        function recalcTotals() {
            let orderTotal = 0;
            const rows = document.querySelectorAll('.item-table tbody tr');
            rows.forEach(row => {
                const priceInput = row.querySelector('.unit-price');
                const qtyInput = row.querySelector('.quantity');
                const lineTotalEl = row.querySelector('.line-total');
                const lineTotal = parseNumber(priceInput) * parseNumber(qtyInput);
                orderTotal += lineTotal;
                lineTotalEl.textContent = formatVnd(lineTotal);
            });

            const orderTotalEl = document.getElementById('orderTotal');
            if (orderTotalEl) {
                orderTotalEl.textContent = formatVnd(orderTotal);
            }
        }

        document.addEventListener('input', function (e) {
            if (e.target.classList.contains('unit-price') || e.target.classList.contains('quantity')) {
                recalcTotals();
            }
        });

        document.addEventListener('DOMContentLoaded', recalcTotals);
        recalcTotals();
    })();
</script>
