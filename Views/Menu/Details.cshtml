@model SWD392_PROJECT.Models.Product

@{
    ViewData["Title"] = "Product Details";
}

<div class="container mt-4">
    <div class="row">
        <!-- Back Button -->
        <div class="col-12 mb-3">
            <a href="@Url.Action("Browse", "Menu")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Menu
            </a>
        </div>
    </div>

    <div class="row">
        <!-- Product Image -->
        <div class="col-md-6">
            <div style="height: 400px; background-color: #f5f5f5; border-radius: 8px; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Name" style="width: 100%; height: 100%; object-fit: cover;">
                }
                else
                {
                    <i class="fas fa-image" style="font-size: 5rem; color: #ccc;"></i>
                }
            </div>
        </div>

        <!-- Product Details -->
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body">
                    <!-- Category -->
                    <span class="badge bg-info mb-3">@Model.Category</span>

                    <!-- Product Name -->
                    <h1 class="card-title mb-3">@Model.Name</h1>

                    <!-- Price -->
                    <div class="mb-3">
                        <p class="text-muted mb-1">Price</p>
                        <h2 class="text-success">₫@Model.Price.ToString("N0")</h2>
                    </div>

                    <!-- Availability Status -->
                    <div class="mb-3">
                        @if (Model.IsAvailable)
                        {
                            <span class="badge bg-success"><i class="fas fa-check-circle"></i> Available</span>
                        }
                        else
                        {
                            <span class="badge bg-danger"><i class="fas fa-times-circle"></i> Not Available</span>
                        }
                    </div>

                    <!-- Selling Time -->
                    <div class="mb-3">
                        <p class="text-muted mb-1"><i class="fas fa-clock"></i> Selling Time</p>
                        <p class="mb-0">@Model.SellingTime</p>
                    </div>

                    <!-- Description -->
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="mb-4">
                            <p class="text-muted mb-1">Description</p>
                            <p class="mb-0">@Model.Description</p>
                        </div>
                    }

                    <!-- Action Buttons -->
                    <div class="d-grid gap-2">
                        @if (Model.IsAvailable)
                        {
                            <button class="btn btn-success btn-lg" onclick="addToCart(@Model.ProductId, '@Model.Name', @Model.Price)">
                                <i class="fas fa-shopping-cart"></i> Add to Cart
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-secondary btn-lg" disabled>
                                <i class="fas fa-ban"></i> Currently Unavailable
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function addToCart(productId, productName, price) {
    alert(`Added "${productName}" to cart!\nPrice: ₫${price.toLocaleString('en-US')}`);
    console.log(`Product ${productId} added to cart`);
}
</script>
