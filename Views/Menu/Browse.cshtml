@model List<SWD392_PROJECT.Models.Product>
@using System.Linq

@{
    ViewData["Title"] = "Browse Menu";
}

<div class="container mt-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-6">
                <i class="fas fa-utensils"></i> Browse Menu
            </h1>
            <p class="text-muted">Explore our delicious food options</p>
        </div>
    </div>

    <!-- Error Messages -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Search and Filter -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body">
                    <form method="get" class="row g-3">
                        <div class="col-md-6">
                            <input type="text" name="search" class="form-control" 
                                   placeholder="Search products..." 
                                   value="@ViewBag.SearchTerm">
                        </div>
                        <div class="col-md-4">
                            <select name="category" class="form-select">
                                <option value="">All Categories</option>
                                @if (ViewBag.Categories != null && ((IEnumerable<string>)ViewBag.Categories).Count() > 0)
                                {
                                    @foreach (var cat in (IEnumerable<string>)ViewBag.Categories)
                                    {
                                        <option value="@cat" 
                                                selected="@(ViewBag.SelectedCategory == cat ? "selected" : "")">
                                            @cat
                                        </option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="fas fa-search"></i> Search
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Debug Info -->
    @if (ViewBag.ProductCount != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <small><strong>Debug:</strong> Found @ViewBag.ProductCount products</small>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Products Grid -->
    @if (Model != null && Model.Count > 0)
    {
        <div class="row">
            @foreach (var product in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm hover-shadow">
                        <!-- Product Image -->
                        <div class="product-image-container" style="height: 250px; overflow: hidden; background-color: #f5f5f5;">
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" alt="@product.Name" 
                                     class="card-img-top" style="height: 100%; object-fit: cover; width: 100%;" 
                                     onerror="this.style.display='none'">
                            }
                            <div class="d-flex align-items-center justify-content-center h-100" style="background-color: #e9ecef;">
                                <i class="fas fa-image" style="font-size: 3rem; color: #ccc;"></i>
                            </div>
                        </div>

                        <div class="card-body">
                            <!-- Category Badge -->
                            <span class="badge bg-info mb-2">@product.Category</span>

                            <!-- Product Name -->
                            <h5 class="card-title">@product.Name</h5>

                            <!-- Description -->
                            @if (!string.IsNullOrEmpty(product.Description))
                            {
                                <p class="card-text text-muted small">
                                    @(product.Description.Length > 100 
                                        ? product.Description.Substring(0, 100) + "..." 
                                        : product.Description)
                                </p>
                            }

                            <!-- Selling Time -->
                            <p class="small text-secondary">
                                <i class="fas fa-clock"></i> @product.SellingTime
                            </p>
                        </div>

                        <div class="card-footer bg-transparent">
                            <div class="d-flex justify-content-between align-items-center">
                                <!-- Price -->
                                <div>
                                    <span class="h5 text-success mb-0">
                                        ₫@product.Price.ToString("N0")
                                    </span>
                                </div>

                                <!-- Actions -->
                                <div>
                                    <a href="@Url.Action("Details", "Menu", new { id = product.ProductId })" 
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-eye"></i> View
                                    </a>
                                    <button class="btn btn-sm btn-success" onclick="addToCart(@product.ProductId, '@product.Name', @product.Price)">
                                        <i class="fas fa-shopping-cart"></i> Add
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-warning text-center" role="alert">
            <i class="fas fa-inbox"></i>
            <p class="mb-2">No products found.</p>
            <small class="text-muted">
                Please check that products have been inserted into the database.
                <br />
                <a href="@Url.Action("Debug", "Menu")" target="_blank" class="link-secondary">View Debug Info</a>
            </small>
        </div>
    }
</div>

<style>
.hover-shadow {
    transition: box-shadow 0.3s ease, transform 0.3s ease;
}

.hover-shadow:hover {
    box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    transform: translateY(-2px);
}

.product-image-container {
    position: relative;
}

.card {
    border: 1px solid #dee2e6;
}
</style>

<script>
function addToCart(productId, productName, price) {
    alert(`Added "${productName}" to cart!\nPrice: ₫${price.toLocaleString('en-US')}`);
    console.log(`Product ${productId} added to cart`);
}
</script>
