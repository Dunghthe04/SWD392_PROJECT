@model SWD392_PROJECT.ViewModels.EditOrderViewModel
@{
    ViewData["Title"] = "Update Order";
}

<h1>Update Order #@Model.OrderId</h1>

<p><strong>Student:</strong> @Model.StudentName</p>
<p><strong>Status:</strong> @Model.Status</p>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    var alertClass = Model.IsConflict ? "alert-warning" : "alert-danger";
    <div class="alert @alertClass" role="alert">@Model.Message</div>
}

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="OrderId" />
    <input type="hidden" asp-for="Version" />
    <input type="hidden" asp-for="StudentName" />
    <input type="hidden" asp-for="Status" />

    <div class="mb-3">
        <label asp-for="Notes" class="form-label">Notes</label>
        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
    </div>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Item</th>
                <th>Unit Price</th>
                <th>Quantity</th>
            </tr>
        </thead>
        <tbody>
        @for (var i = 0; i < Model.Items.Count; i++)
        {
            <tr>
                <td>
                    @Model.Items[i].ItemName
                    <input type="hidden" asp-for="Items[i].MenuItemId" />
                    <input type="hidden" asp-for="Items[i].ItemName" />
                </td>
                <td>
                    @Model.Items[i].UnitPrice.ToString("N0")
                    <input type="hidden" asp-for="Items[i].UnitPrice" />
                </td>
                <td>
                    <input asp-for="Items[i].Quantity" class="form-control" min="1" />
                </td>
            </tr>
        }
        </tbody>
    </table>

    <button type="submit" name="submitAction" value="save" class="btn btn-primary">Save Update</button>
    <button type="submit" name="submitAction" value="cancel" class="btn btn-secondary">Cancel</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</form>
