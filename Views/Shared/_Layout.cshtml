<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SWD392_PROJECT</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Bootstrap CSS from CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SWD392_PROJECT.styles.css" asp-append-version="true" />
    <style>
        .dropdown-menu {
            border-radius: 10px;
            box-shadow: 0 4px 16px rgba(0,0,0,0.12);
            padding: 6px;
            min-width: 150px;
        }

        .dropdown-item {
            border-radius: 6px;
            font-size: 13.5px;
            padding: 7px 10px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .dropdown-item svg {
                flex-shrink: 0;
            }

        .dropdown-divider {
            margin: 4px 6px;
        }

        .dropdown-item.text-danger:hover {
            background: #fff1f1;
        }

        .logout-btn {
            width: 100%;
            background: none;
            border: none;
            text-align: left;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
            <div class="container-fluid navbar-container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    🍽️ Campus Food
                </a>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="navbar-nav-center">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                         <a class="nav-link" asp-area="" asp-controller="Payment" asp-action="Index">Payment</a>
                        <a class="nav-link" asp-area="" asp-controller="Order" asp-action="Index">Orders</a>
                        <a class="nav-link" asp-area="" asp-controller="Promotion" asp-action="GetAllPromotions">Promotions</a>
                        @if (User.IsInRole("Manager"))
                        {
                            <a class="nav-link" asp-area="" asp-controller="Issue" asp-action="List">Issues</a>
                            <a class="nav-link" asp-area="" asp-controller="SalesReport" asp-action="Index">Sales Report</a>
                            <a class="nav-link" asp-area="" asp-controller="Product" asp-action="Index">Products</a>
                        }
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    </div>
                }

                <div class="navbar-actions">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (User.IsInRole("Manager"))
                        {
                            <div class="notification-container">
                                <button class="btn btn-notification" id="notificationBtn" title="Notifications" type="button">
                                    <svg class="bell-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                                        <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                                    </svg>
                                    <span class="badge badge-notification" id="notificationBadge" style="display: none;">
                                        <span id="notificationCount">0</span>
                                    </span>
                                </button>
                                <div class="notification-panel" id="notificationPanel" style="display: none;">
                                    <div class="notification-header">
                                        <h3>Notifications</h3>
                                        <button class="btn-close-panel" id="closePanelBtn">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <line x1="18" y1="6" x2="6" y2="18"></line>
                                                <line x1="6" y1="6" x2="18" y2="18"></line>
                                            </svg>
                                        </button>
                                    </div>
                                    <div class="notification-list" id="notificationList">
                                        <div class="notification-loading">Loading notifications...</div>
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="dropdown">
                            <button class="btn btn-user dropdown-toggle" type="button" id="userMenu"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                    <circle cx="12" cy="7" r="4" />
                                </svg>
                                <span>@(User.FindFirst("Role")?.Value ?? "User")</span>
                            </button>

                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                                <li>
                                    <a class="dropdown-item" asp-controller="Profile" asp-action="Index">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                             fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                            <circle cx="12" cy="7" r="4" />
                                        </svg>
                                        My Profile
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Profile" asp-action="Edit">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                             fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                        </svg>
                                        Edit Profile
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form method="post" asp-controller="Auth" asp-action="Logout">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger logout-btn">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                                 fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                                                <polyline points="16 17 21 12 16 7" />
                                                <line x1="21" y1="12" x2="9" y2="12" />
                                            </svg>
                                            Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="btn btn-primary btn-sm" asp-controller="Auth" asp-action="Login">Login</a>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Manager"))
    {
        <script>
            const notificationBtn = document.getElementById('notificationBtn');
            const notificationPanel = document.getElementById('notificationPanel');
            const notificationList = document.getElementById('notificationList');
            const closePanelBtn = document.getElementById('closePanelBtn');
            const notificationBadge = document.getElementById('notificationBadge');
            const notificationCount = document.getElementById('notificationCount');

            function updateNotificationCount() {
                fetch('/Issue/GetUnreadCount')
                    .then(r => r.json())
                    .then(data => {
                        if (data.success) {
                            if (data.count > 0) {
                                notificationCount.textContent = data.count > 99 ? '99+' : data.count;
                                notificationBadge.style.display = 'flex';
                            } else {
                                notificationBadge.style.display = 'none';
                            }
                        }
                    })
                    .catch(e => console.error(e));
            }

            async function loadNotifications() {
                try {
                    notificationList.innerHTML = '<div class="notification-loading">Loading notifications...</div>';
                    const data = await fetch('/Issue/GetUnreadNotifications').then(r => r.json());
                    if (data.success && data.notifications.length > 0) {
                        notificationList.innerHTML = data.notifications.map(n => `
                            <div class="notification-item unread" onclick="viewIssue(${n.issueId})">
                                <div class="notification-dot"></div>
                                <div class="notification-content">
                                    <p class="notification-message">${escapeHtml(n.message)}</p>
                                    <p class="notification-time">${n.createdDate}</p>
                                </div>
                            </div>
                        `).join('');
                    } else {
                        notificationList.innerHTML = '<div class="notification-empty">No new notifications</div>';
                    }
                } catch (e) {
                    notificationList.innerHTML = '<div class="notification-empty">Error loading notifications</div>';
                }
            }

            function escapeHtml(text) {
                const d = document.createElement('div');
                d.textContent = text;
                return d.innerHTML;
            }

            function viewIssue(id) { window.location.href = `/Issue/Details/${id}`; }

            notificationBtn.addEventListener('click', async function(e) {
                e.preventDefault();
                const hidden = notificationPanel.style.display === 'none' || !notificationPanel.style.display;
                if (hidden) { await loadNotifications(); notificationPanel.style.display = 'block'; }
                else notificationPanel.style.display = 'none';
            });

            closePanelBtn.addEventListener('click', e => { e.stopPropagation(); notificationPanel.style.display = 'none'; });

            document.addEventListener('click', function(e) {
                if (!notificationPanel.contains(e.target) && !notificationBtn.contains(e.target))
                    notificationPanel.style.display = 'none';
            });

            document.addEventListener('DOMContentLoaded', updateNotificationCount);
            setInterval(updateNotificationCount, 30000);
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
