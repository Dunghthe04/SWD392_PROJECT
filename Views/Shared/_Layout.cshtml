<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SWD392_PROJECT</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SWD392_PROJECT.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light sticky-top">
            <div class="container-fluid navbar-container">
                <!-- Brand -->
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    🍽️ Campus Food
                </a>

                <!-- Nav Items (Center) -->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="navbar-nav-center">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        <a class="nav-link" asp-area="" asp-controller="Order" asp-action="Index">Orders</a>
                        @if (User.IsInRole("Manager"))
                        {
                            <a class="nav-link" asp-area="" asp-controller="Issue" asp-action="List">Issues</a>
                        }
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    </div>
                }

                <!-- Right Actions -->
                <div class="navbar-actions">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="d-flex align-items-center gap-3">
                            <!-- Notification Bell (Manager Only) -->
                            @if (User.IsInRole("Manager"))
                            {
                                <a class="nav-link position-relative" asp-area="" asp-controller="Issue" asp-action="Notifications" title="Notifications">
                                    <span style="font-size: 1.25rem; cursor: pointer;">🔔</span>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="notificationBadge" style="display: none;">
                                        <span id="notificationCount">0</span>
                                    </span>
                                </a>
                            }

                            <!-- User Menu -->
                            <div class="dropdown">
                                <button class="btn btn-link nav-link dropdown-toggle" type="button" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span>👤 <span id="userRole">@(User.FindFirst("Role")?.Value ?? "User")</span></span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                                    <li>
                                        <form method="post" asp-controller="Auth" asp-action="Logout">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item">
                                                <i class="bi bi-box-arrow-right"></i> Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    }
                    else
                    {
                        <a class="btn btn-primary btn-sm" asp-controller="Auth" asp-action="Login">Login</a>
                    }

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" 
                            aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                </div>
            </div>
        </nav>
    </header>
    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- Notification Bell Script -->
    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Manager"))
    {
        <script>
            // Update notification count
            function updateNotificationCount() {
                fetch('/Issue/GetNotificationCount')
                    .then(response => response.json())
                    .then(data => {
                        const badge = document.getElementById('notificationBadge');
                        const count = document.getElementById('notificationCount');
                        if (data.count > 0) {
                            count.textContent = data.count;
                            badge.style.display = 'inline-block';
                        } else {
                            badge.style.display = 'none';
                        }
                    })
                    .catch(error => console.error('Error updating notification count:', error));
            }

            // Update on page load
            document.addEventListener('DOMContentLoaded', updateNotificationCount);

            // Update every 30 seconds
            setInterval(updateNotificationCount, 30000);
        </script>
    }
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
