<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SWD392_PROJECT</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SWD392_PROJECT.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
            <div class="container-fluid navbar-container">
                <!-- Brand -->
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    🍽️ Campus Food
                </a>

                <!-- Nav Items (Center) -->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="navbar-nav-center">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        <a class="nav-link" asp-area="" asp-controller="Order" asp-action="Index">Orders</a>
                        <a class="nav-link" asp-area="" asp-controller="Promotion" asp-action="GetAllPromotions">Promotions</a>
                        @if (User.IsInRole("Manager"))
                        {
                            <a class="nav-link" asp-area="" asp-controller="Issue" asp-action="List">Issues</a>
                        }
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    </div>
                }

                <!-- Right Actions -->
                <div class="navbar-actions">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <!-- Notification Bell (Manager Only) -->
                        @if (User.IsInRole("Manager"))
                        {
                            <div class="notification-container">
                                <button class="btn btn-notification" id="notificationBtn" title="Notifications" type="button">
                                    <svg class="bell-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                                        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                                    </svg>
                                    <span class="badge badge-notification" id="notificationBadge" style="display: none;">
                                        <span id="notificationCount">0</span>
                                    </span>
                                </button>

                                <!-- Notification Panel (YouTube Style) -->
                                <div class="notification-panel" id="notificationPanel" style="display: none;">
                                    <div class="notification-header">
                                        <h3>Notifications</h3>
                                        <button class="btn-close-panel" id="closePanelBtn">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <line x1="18" y1="6" x2="6" y2="18"></line>
                                                <line x1="6" y1="6" x2="18" y2="18"></line>
                                            </svg>
                                        </button>
                                    </div>
                                    <div class="notification-list" id="notificationList">
                                        <div class="notification-loading">Loading notifications...</div>
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- User Menu -->
                        <div class="dropdown">
                            <button class="btn btn-user dropdown-toggle" type="button" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false">
                                <svg class="user-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                    <circle cx="12" cy="7" r="4"/>
                                </svg>
                                <span id="userRole">@(User.FindFirst("Role")?.Value ?? "User")</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                                <li>
                                    <form method="post" asp-controller="Auth" asp-action="Logout">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item">
                                            Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="btn btn-primary btn-sm" asp-controller="Auth" asp-action="Login">Login</a>
                    }
                </div>
            </div>
        </nav>
    </header>
    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- Notification Panel Script -->
    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Manager"))
    {
        <script>
            // DOM Elements
            const notificationBtn = document.getElementById('notificationBtn');
            const notificationPanel = document.getElementById('notificationPanel');
            const notificationList = document.getElementById('notificationList');
            const closePanelBtn = document.getElementById('closePanelBtn');
            const notificationBadge = document.getElementById('notificationBadge');
            const notificationCount = document.getElementById('notificationCount');

            // Update notification count
            function updateNotificationCount() {
                fetch('/Issue/GetUnreadCount')
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            if (data.count > 0) {
                                notificationCount.textContent = data.count > 99 ? '99+' : data.count;
                                notificationBadge.style.display = 'flex';
                            } else {
                                notificationBadge.style.display = 'none';
                            }
                        }
                    })
                    .catch(error => console.error('Error updating notification count:', error));
            }

            // Load notifications into panel
            async function loadNotifications() {
                try {
                    notificationList.innerHTML = '<div class="notification-loading">Loading notifications...</div>';
                    const response = await fetch('/Issue/GetUnreadNotifications');
                    const data = await response.json();

                    if (data.success && data.notifications.length > 0) {
                        notificationList.innerHTML = data.notifications.map(notification => `
                            <div class="notification-item unread" onclick="viewIssue(${notification.issueId})">
                                <div class="notification-dot"></div>
                                <div class="notification-content">
                                    <p class="notification-message">${escapeHtml(notification.message)}</p>
                                    <p class="notification-time">${notification.createdDate}</p>
                                </div>
                            </div>
                        `).join('');
                    } else {
                        notificationList.innerHTML = '<div class="notification-empty">No new notifications</div>';
                    }
                } catch (error) {
                    console.error('Error loading notifications:', error);
                    notificationList.innerHTML = '<div class="notification-empty">Error loading notifications</div>';
                }
            }

            // Escape HTML to prevent XSS
            function escapeHtml(text) {
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }

            // View issue
            function viewIssue(issueId) {
                window.location.href = `/Issue/Details/${issueId}`;
            }

            // Toggle notification panel
            notificationBtn.addEventListener('click', async function(e) {
                e.preventDefault();
                if (notificationPanel.style.display === 'none' || !notificationPanel.style.display) {
                    await loadNotifications();
                    notificationPanel.style.display = 'block';
                } else {
                    notificationPanel.style.display = 'none';
                }
            });

            // Close panel button
            closePanelBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                notificationPanel.style.display = 'none';
            });

            // Close panel when clicking outside
            document.addEventListener('click', function(e) {
                if (!notificationPanel.contains(e.target) && !notificationBtn.contains(e.target)) {
                    notificationPanel.style.display = 'none';
                }
            });

            // Update on page load
            document.addEventListener('DOMContentLoaded', function() {
                updateNotificationCount();
            });

            // Update notification count every 30 seconds
            setInterval(updateNotificationCount, 30000);
        </script>
    }
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
