@model IEnumerable<SWD392_PROJECT.Models.Payment>

@{
    ViewData["Title"] = "Payments";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3>Payments</h3>
                <a asp-action="Index" class="btn btn-primary">Create Payment</a>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Order</th>
                            <th>Amount (VND)</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach(var p in Model)
                    {
                        <tr>
                            <td>@p.PaymentId</td>
                            <td>@p.OrderId</td>
                            <td>@String.Format("{0:N0}", (decimal)p.Amount)</td>
                            <td>
                                @if (p.Status.Equals("Success", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge bg-success">@p.Status</span>
                                }
                                else if (p.Status.Equals("Cancelled", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge bg-warning">@p.Status</span>
                                }
                                else if (p.Status.Equals("Timeout", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge bg-danger">@p.Status</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@p.Status</span>
                                }
                            </td>
                            <td><a asp-action="Result" asp-route-paymentId="@p.PaymentId" class="btn btn-sm btn-outline-primary">View</a></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
