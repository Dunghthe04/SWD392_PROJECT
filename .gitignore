## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
bin/
obj/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Visual Studio cache files
.vs/

# Rider / VS Code
.idea/
.vscode/

# ASP.NET Core
wwwroot/lib/
wwwroot/dist/

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Environment variables
.env

# Publish output
publish/

# NuGet
*.nupkg
packages/
!packages/build/
!packages/repositories.config

# Resharper
_ReSharper*/
*.DotSettings.user

# IIS Express
iisexpress/
*.vspscc
*.vssscc

# SQL Server files
*.mdf
*.ldf

# Azure
*.publishsettings

# Backup files
*.bak

# Others
node_modules/
dist/

appsettings.Development.json
appsettings.json

# DoctoCode / Generated from design
DoctoCode/

# Editor temporary files
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Test Results
*.trx
TestResults/

# Code Coverage
coverage/
.coverage

# SonarQube
.sonarqube/

# Database files
*.db
*.sqlite

# Temporary files
temp/
tmp/

# Python files and virtual environments
*.py
*.pyc
*.pyo
__pycache__/
venv/
env/
ENV/
.venv/
.env.local

# IDE and Editor files
*.vscode
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# macOS specific
.DS_Store
.AppleDouble
.LSOverride

# Windows specific
Thumbs.db
desktop.ini

# Git-related
.git/
.gitattributes